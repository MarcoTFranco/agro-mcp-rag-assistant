# === Agro MCP RAG Assistant — Variáveis de Ambiente ===
# Copie este arquivo para .env e preencha os valores.
# NUNCA commite o .env!

# URL pública do Ollama exposta via ngrok no Google Colab
# (copie do output do notebook Colab após iniciar o túnel)
OLLAMA_BASE_URL=https://SEU-TUNEL.ngrok-free.app

# Modelo do Ollama a ser usado (padrão: llama3)
OLLAMA_MODEL=llama3.1

# Chave da API OpenWeatherMap (gratuita: https://openweathermap.org/api)
# Deixe vazio para rodar sem dados climáticos (degradação graciosa)
OPENWEATHERMAP_API_KEY=

# Token ngrok (para o notebook Colab)
NGROK_AUTHTOKEN=seu_token_aqui
